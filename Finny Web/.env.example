# Duitku Payment Gateway
# Daftar merchant di https://sandbox.duitku.com (sandbox) atau https://partner.duitku.com (production)
DUITKU_MERCHANT_CODE=your_merchant_code
DUITKU_API_KEY=your_api_key

# Sandbox: https://api-sandbox.duitku.com
# Production: https://api.duitku.com
DUITKU_BASE_URL=https://api-sandbox.duitku.com

# Domain publik server ini (digunakan untuk callback URL ke Duitku)
# Contoh: https://finny.id atau https://your-app.fly.dev
WEBHOOK_DOMAIN=https://your-domain.com

# Port server (default: 3000)
PORT=3000
